<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ManagerCommands.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ManagerCommands.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/ICON.png"
        Title="ManagerCommands">
    <Grid Background="{DynamicResource MyBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *" Background="{DynamicResource MyBackground}">
            <TextBox Grid.Row="1" TextChanged="NameSearch_OnTextChanged" x:Name="NameSearch" Watermark="Search by Name"
                     Margin="10" />
            <ListBox Grid.Row="2" x:Name="ListCommendS"
                     Background="{DynamicResource MyBackground}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch" />
        </Grid>
        <Grid Grid.Column="1"
              RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, *"
              Background="{DynamicResource MyBackground}"
              Margin="10">

            <StackPanel Grid.Row="0" Spacing="25" Margin="0,0,0,20">
                <TextBox x:Name="NameCommend"
                         Watermark="Command Name"
                         Foreground="White"
                         Padding="5,8" />

                <CheckBox x:Name="ChangeCommend"
                          Content="Create Change Command"
                          Foreground="FloralWhite"
                          Margin="0,0,0,-10" />

                <Button Content="Create Command"
                        Click="CreateCommendButton_OnClick"
                        HorizontalAlignment="Stretch"
                        Padding="15,5"
                        Height="45" />

                <Button Content="Import Commands"
                        Click="ImportCommendsButton_OnClick"
                        HorizontalAlignment="Stretch"
                        Padding="15,5"
                        Height="45" />
                <TextBox x:Name="PathSave"/>
            </StackPanel>
            <Separator Grid.Row="1" Background="Gray" Opacity="0.3" Margin="0,10" />

            <StackPanel Grid.Row="2" Spacing="5" Margin="0,0,0,20">
                <Label Content="Delay between commands (ms):" Foreground="Gray" FontSize="12" />
                <NumericUpDown Name="Timer"
                               ValueChanged="Timer_OnValueChanged"
                               Minimum="100" Maximum="10000" Increment="10"
                               FormatString="0" />
            </StackPanel>

            <HeaderedContentControl Grid.Row="3" Header="Terminal Settings" Foreground="Gold" FontWeight="Bold">
                <StackPanel Spacing="10" Margin="0,10,0,0">

                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto,Auto">

                        <Label Grid.Row="0" Grid.Column="0" Name="LabelHexTerminalTextInput" Content="Background:"
                               VerticalAlignment="Center" Foreground="FloralWhite" Margin="0,0,10,0" />
                        <TextBox Grid.Row="0" TextChanged="HexTerminalTextInput_OnTextChanged" Grid.Column="1"
                                 x:Name="HexTerminalTextInput" Watermark="#123456 (Hex)" />

                        <Label Grid.Row="1" x:Name="LabelHexColorTextInput" Grid.Column="0" Content="Text Color:"
                               VerticalAlignment="Center" Foreground="FloralWhite" />
                        <TextBox Grid.Row="1" Grid.Column="1" TextChanged="HexColorTextInput_OnTextChanged"
                                 x:Name="HexColorTextInput" Watermark="#FFFFFF (Hex)" />

                        <Label Grid.Row="2" Name="LabelFontSize" Grid.Column="0" Content="Font Size:"
                               VerticalAlignment="Center" Foreground="FloralWhite" />
                        <NumericUpDown Grid.Row="2" Grid.Column="1" Name="sizeFont"
                                       ValueChanged="SizeFont_OnValueChanged"
                                       Minimum="4" Maximum="100" Increment="1" Value="12" />

                        <Label Grid.Row="3" Grid.Column="0" Name="LabelFontFamily" Content="Font Family:"
                               VerticalAlignment="Center" Foreground="FloralWhite" />
                        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="FontFamilyInput"
                                  SelectionChanged="FontFamilyInput_OnSelectionChanged"
                                  HorizontalAlignment="Stretch"
                                  Foreground="White" Background="#1E1E1E" />
                        <Button Grid.Row="4" Content="Reset settings"
                                Click="ResetSettingsButton_OnClick"
                                HorizontalAlignment="Stretch"
                                Padding="15,5"
                                Height="45" />
                    </Grid>


                </StackPanel>
            </HeaderedContentControl>


        </Grid>
    </Grid>

</Window>
