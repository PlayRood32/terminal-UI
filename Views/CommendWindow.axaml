<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ManagerCommands.Views.CommendWindow"
        KeyUp="InputElement_OnKeyUp"
        Title="Command Manager"
        Background="{DynamicResource MyBackground}">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="1" ColumnDefinitions="*, *">
            <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" Margin="5">
                <Label Content="Terminal Output" Foreground="Gray" Margin="5,0" />
                <TextBox Grid.Row="1" x:Name="Terminal"
                         KeyUp="Terminal_OnKeyUp"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         Background="Black"
                         Foreground="White"
                         FontFamily="Cascadia Code,Consolas,Monospace"
                         TextWrapping="Wrap">

                    <TextBox.Styles>
                        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                            <Setter Property="Background" Value="{Binding #Terminal.Background}" />
                        </Style>

                        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                            <Setter Property="Background" Value="{Binding #Terminal.Background}" />
                        </Style>

                        <Style Selector="TextBox:pointerover">
                            <Setter Property="Foreground" Value="{Binding #Terminal.Foreground}" />
                        </Style>
                        <Style Selector="TextBox:focus">
                            <Setter Property="Foreground" Value="{Binding #Terminal.Foreground}" />
                        </Style>
                    </TextBox.Styles>
                </TextBox>

                <TextBox Grid.Row="2" x:Name="TerminalInput" IsVisible="False"
                         Watermark="Type here (e.g. R, Y) and press Enter..."
                         Background="#1a1a1a" Foreground="White" Margin="0,5,0,0" />
            </Grid>

            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="10" Margin="10">
                    <ComboBox x:Name="Commmends" HorizontalAlignment="Stretch" Height="32" Foreground="White"
                              Background="#1E1E1E" />

                    <TextBox x:Name="Location"
                             Watermark="Execution Location (e.g. /home/user)"
                             Foreground="White" />

                    <TextBox x:Name="ContentCommend"
                             Watermark="Command Content"
                             AcceptsReturn="True"
                             Height="100"
                             VerticalContentAlignment="Top"
                             Foreground="White" />

                    <Separator Background="Gray" Margin="0,10" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="?" Foreground="Yellow" Click="ExplainWin_OnClick" />
                        <Button Name="SaveDate" Content="Save" Foreground="White" />
                        <Button Name="BackMain" Content="Back" Foreground="White" />
                        <Button Name="RunCommand" Content="Run Command" Foreground="White" Background="Green" />
                    </StackPanel>

                    <StackPanel x:Name="VariablesPanel" Spacing="5" />

                    <Separator Background="Gray" Margin="0,10" />
                    <Label Content="Description" Foreground="White" FontWeight="Bold" />

                    <TextBox x:Name="Description"
                             Watermark="Description"
                             Foreground="White"
                             Height="250"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,10,20" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
